# Copy to .env and fill in. Never commit .env.
# Postgres (Railway provides this in production)
DATABASE_URL="postgresql://user:password@localhost:5432/freightconnect?schema=public"

# Auth (Phase 2)
AUTH_SECRET=""

# Email — Resend (Phase 2/5)
RESEND_API_KEY=""
EMAIL_FROM="FreightConnect <noreply@freightconnect.example>"

# Object storage — Railway bucket / S3-compatible (Phase 4)
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET="freightconnect-kyc"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
